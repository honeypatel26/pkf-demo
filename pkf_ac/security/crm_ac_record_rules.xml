<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Allow reading/writing CRM leads if user is in A&C allowed users list -->
        <record id="rule_crm_lead_ac_allowed_users" model="ir.rule">
            <field name="name">CRM Lead: A&amp;C Assigned Access</field>
            <field name="model_id" ref="crm.model_crm_lead"/>

            <field name="groups" eval="[
                (4, ref('pkf_ac.group_pkf_ac_user')),
                (4, ref('pkf_ac.group_pkf_ac_manager')),
                (4, ref('pkf_ac.group_pkf_ac_senior_manager')),
                (4, ref('pkf_ac.group_pkf_ac_partner')),
                (4, ref('pkf_ac.group_pkf_ac_admin'))
            ]"/>

            <field name="domain_force">
                ['|',
                    ('user_id', '=', user.id),
                    ('ac_allowed_user_ids', 'in', [user.id])
                ]
            </field>

            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

    </data>
</odoo>