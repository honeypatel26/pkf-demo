<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Join (Office/Company limitation) -->
        <record id="rule_pkf_ac_join_office_company" model="ir.rule">
            <field name="name">Join</field>
            <field name="model_id" ref="pkf_ac.model_pkf_ac_evaluation"/>
            <field name="domain_force">[('pkf_office_id', 'in', company_ids + [False])]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- Own records: User + Manager -->
        <record id="rule_pkf_ac_own_records" model="ir.rule">
            <field name="name">PKF A&amp;C Access to own records</field>
            <field name="model_id" ref="pkf_ac.model_pkf_ac_evaluation"/>
            <field name="groups" eval="[(4, ref('pkf_ac.group_pkf_ac_user')),
                                       (4, ref('pkf_ac.group_pkf_ac_manager'))]"/>

            <!-- OR of 5 conditions => only 4 '|' operators -->
            <field name="domain_force">
                ['|','|','|','|',
                 ('create_uid','=',user.id),
                 ('manager_assigned_id','=',user.id),
                 ('partner_reviewer_id','=',user.id),
                 ('engagement_partner_id','=',user.id),
                 ('assignee_ids','in',[user.id])]
            </field>

            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- All records: Senior Manager + Partner + Admin -->
        <record id="rule_pkf_ac_all_records" model="ir.rule">
            <field name="name">PKF A&amp;C Access to all records</field>
            <field name="model_id" ref="pkf_ac.model_pkf_ac_evaluation"/>
            <field name="groups" eval="[(4, ref('pkf_ac.group_pkf_ac_senior_manager')),
                                       (4, ref('pkf_ac.group_pkf_ac_partner')),
                                       (4, ref('pkf_ac.group_pkf_ac_admin'))]"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

    </data>
</odoo>