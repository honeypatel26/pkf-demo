<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pkf_ac_evaluation_form_team_independence" model="ir.ui.view">
        <field name="name">pkf.ac.evaluation.form.team.independence</field>
        <field name="model">pkf.ac.evaluation</field>
        <field name="inherit_id" ref="pkf_ac.view_pkf_ac_evaluation_form"/>
        <field name="priority" eval="70"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='trend_research']" position="after">
                <page string="Team Independence" name="team_independence">
                    <field name="team_independence_ids" nolabel="1" domain="[('is_draft', '=', False)]">
                        <list create="0" delete="0">
                            <field name="is_draft" optional="hide"/>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="confirmation" decoration-danger="confirmation == 'decline'" decoration-warning="confirmation == 'pending'"
                           decoration-success="confirmation == 'accept'"/>
                            <field name="date_of_confirmation"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
