<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_engagement_letter" model="ir.actions.report">
        <field name="name">Engagement Letter</field>
        <field name="model">engagement.letter</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">engagement_letter.report_engagement_letter</field>
        <field name="report_file">engagement_letter.report_engagement_letter</field>
        <field name="print_report_name">'Engagement Letter - %s' % (object.name or '')</field>
    </record>

    <template id="report_engagement_letter">
        <t t-foreach="docs" t-as="o">
            <t t-call="web.external_layout">
                <main>
                    <div class="page">
                    <div class="mb-4" t-if="o.partner_id">
                        <p><strong>Customer:</strong> <span t-field="o.partner_id.name"/></p>
                    </div>

                    <h2 class="mb-4">
                        <span t-field="o.name"/>
                    </h2>

                    <t t-foreach="o.block_ids.sorted(key=lambda b: (b.sequence, b.id))" t-as="b">
                        <div class="mt-4">
                            <h3 class="mb-3">
                                <span t-out="b.title or b.template_id.name or ''"/>
                            </h3>

                            <div t-if="b.description" class="mb-3">
                                <div t-out="b.description"/>
                            </div>

                            <t t-if="b.line_ids">
                                <t t-set="has_discount"
                                   t-value="any(l.discount for l in b.line_ids)"/>

                                <table class="table table-sm table-borderless" name="lines_table">
                                    <thead>
                                        <tr>
                                            <th>Description</th>
                                            <th class="text-end">Qty</th>
                                            <th class="text-end">Unit Price</th>

                                            <th t-if="has_discount" class="text-end">Discount (%)</th>

                                            <th class="text-end">Subtotal</th>
                                            <th class="text-end">Taxes</th>
                                            <th class="text-end">Total</th>
                                        </tr>
                                    </thead>

                                    <tbody>
                                        <t t-foreach="b.line_ids.sorted(key=lambda l: (l.sequence, l.id))" t-as="l">

                                            <!-- NORMAL LINE -->
                                            <tr t-if="l.display_type == 'line'">
                                                <td>
                                                    <span t-field="l.name"/>
                                                </td>

                                                <td class="text-end">
                                                    <span t-field="l.product_uom_qty"/>
                                                    <span t-field="l.product_uom_id"/>
                                                </td>

                                                <td class="text-end">
                                                    <span t-field="l.price_unit"
                                                          t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>

                                                <td t-if="has_discount" class="text-end">
                                                    <t t-if="l.discount &gt; 0">
                                                        <span t-field="l.discount"/>%
                                                    </t>
                                                </td>

                                                <td class="text-end">
                                                    <span t-field="l.price_subtotal"
                                                          t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>

                                                <td class="text-end">
                                                    <span t-esc="', '.join(l.tax_id.mapped('name'))"/>
                                                </td>

                                                <td class="text-end">
                                                    <span t-field="l.price_total"
                                                          t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                            </tr>

                                        </t>
                                    </tbody>
                                </table>
                            </t>

                        </div>
                        <p style="page-break-after: always;" t-if="not b_last"/>
                    </t>
                    </div>
                </main>
            </t>
        </t>
    </template>
</odoo>
