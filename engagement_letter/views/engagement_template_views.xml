<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- LIST -->
    <record id="view_engagement_letter_template_list" model="ir.ui.view">
        <field name="name">engagement.letter.template.list</field>
        <field name="model">engagement.letter.template</field>
        <field name="arch" type="xml">
            <list string="Engagement Templates">
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_engagement_letter_template_form" model="ir.ui.view">
        <field name="name">engagement.letter.template.form</field>
        <field name="model">engagement.letter.template</field>
        <field name="arch" type="xml">
            <form string="Engagement Template">
                <sheet>
                    <group>
                        <field name="name" class="oe_inline" style="width: 100%;"/>
                    </group>

                    <notebook>
                        <page string="Text">
                            <field name="description" widget="html"/>
                        </page>

                        <page string="Lines">
                            <field name="line_ids" context="{'default_display_type': 'line'}">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="product_id"/>
                                    <field name="product_uom_qty"/>
                                    <field name="product_uom_id"/>
                                    <field name="price_unit"/>
                                    <field name="discount"/>
                                    <field name="price_subtotal" readonly="1"/>
                                    <field name="tax_id" widget="many2many_tags"/>
                                    <field name="price_total" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- SEARCH -->
    <record id="view_engagement_letter_template_search" model="ir.ui.view">
        <field name="name">engagement.letter.template.search</field>
        <field name="model">engagement.letter.template</field>
        <field name="arch" type="xml">
            <search string="Engagement Templates">
                <field name="name"/>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_engagement_letter_templates" model="ir.actions.act_window">
        <field name="name">Templates</field>
        <field name="res_model">engagement.letter.template</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Engagement Template.
            </p>
        </field>
    </record>
</odoo>
