<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_engagement" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.engagement</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_engagement_letter"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-file-text-o"
                        invisible="not engagement_letter_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Engagement</span>
                        <span class="o_stat_text">Letter</span>
                    </div>
                </button>
            </div>
        </field>
    </record>
</odoo>
