<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_applicant_view_form_inherit_pkf" model="ir.ui.view">
        <field name="name">hr.applicant.view.form.inherit.pkf</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Interview Notes">
                    <field name="interview_notes"/>
                </page>
                <page string="AI Analysis">
                    <group class="mt-3">
                        <group>
                            <field name="applicant_resume" filename="applicant_resume_name"/>
                        </group>
                        <group>
                            <field name="ai_analysis_score" readonly="1"/>
                        </group>
                    </group>
                    <separator string="AI Analysis Details"/>
                    <field name="ai_analysis" readonly="1" nolabel="1" placeholder="AI Analysis will appear here..."/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
