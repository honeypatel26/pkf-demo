<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action -->
    <record id="action_timesheet_dashboard" model="ir.actions.act_window">
        <field name="name">Timesheet Dashboard</field>
        <field name="res_model">account.analytic.line</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="domain">[('project_id', '!=', False)]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No timesheets found.
            </p>
            <p>
                Track your employees' time and analyze billable vs non-billable hours.
            </p>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_timesheet_dashboard_graph" model="ir.ui.view">
        <field name="name">account.analytic.line.graph.dashboard</field>
        <field name="model">account.analytic.line</field>
        <field name="arch" type="xml">
            <graph string="Timesheet Dashboard" sample="1" type="bar" js_class="hr_timesheet_graphview">
                <field name="employee_id" type="row"/>
                <field name="billable_category" type="row"/>
                <field name="unit_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_timesheet_dashboard_pivot" model="ir.ui.view">
        <field name="name">account.analytic.line.pivot.dashboard</field>
        <field name="model">account.analytic.line</field>
        <field name="arch" type="xml">
            <pivot string="Timesheet Dashboard" sample="1">
                <field name="employee_id" type="row"/>
                <field name="date" interval="month" type="col"/>
                <field name="billable_category" type="col"/>
                <field name="unit_amount" type="measure"/>
            </pivot>
        </field>
    </record>
    
    <!-- Search View Extension -->
    <record id="timesheet_dashboard_search" model="ir.ui.view">
        <field name="name">account.analytic.line.search.dashboard</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="hr_timesheet.hr_timesheet_line_search"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='groupby']" position="inside">
                <filter string="Billable Category" name="groupby_billable_category" domain="[]" context="{'group_by': 'billable_category'}"/>
            </xpath>
        </field>
    </record>

    <!-- List View Extension -->
    <record id="timesheet_dashboard_tree" model="ir.ui.view">
        <field name="name">account.analytic.line.tree.dashboard</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="hr_timesheet.hr_timesheet_line_tree"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="billable_category" optional="show"/>
            </field>
        </field>
    </record>

    <!-- Bind Views to Action -->
    <record id="action_timesheet_dashboard_view_graph" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_timesheet_dashboard_graph"/>
        <field name="act_window_id" ref="action_timesheet_dashboard"/>
    </record>

    <record id="action_timesheet_dashboard_view_pivot" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="view_timesheet_dashboard_pivot"/>
        <field name="act_window_id" ref="action_timesheet_dashboard"/>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_timesheet_dashboard"
              name="Dashboard"
              parent="hr_timesheet.menu_timesheets_reports"
              action="action_timesheet_dashboard"
              sequence="0"/>
</odoo>
