<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="division_view_form" model="ir.ui.view">
        <field name="name">division.form</field>
        <field name="model">division.division</field>
        <field name="arch" type="xml">
            <form string="Division">
                 <sheet>
                     <group>
                        <field name="name" string="Division"/>
                     </group>
                 </sheet>
            </form>
        </field>
    </record>

    <record id="division_list_view" model="ir.ui.view">
        <field name="name">division.List</field>
        <field name="model">division.division</field>
        <field name="arch" type="xml">
            <list string="Division">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="division_action" model="ir.actions.act_window">
        <field name="name">Division</field>
        <field name="res_model">division.division</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new record
            </p>
        </field>
    </record>
</odoo>
