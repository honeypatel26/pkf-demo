<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="partner_view_form" model="ir.ui.view">
        <field name="name">partner.form</field>
        <field name="model">partner.partner</field>
        <field name="arch" type="xml">
            <form string="Partner">
                 <sheet>
                     <group>
                        <field name="name" string="Partner"/>
                     </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="partner_list_view" model="ir.ui.view">
        <field name="name">partner.List</field>
        <field name="model">partner.partner</field>
        <field name="arch" type="xml">
            <list string="Partner">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="partner_action" model="ir.actions.act_window">
        <field name="name">Partner</field>
        <field name="res_model">partner.partner</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new record
            </p>
        </field>
    </record>
</odoo>
