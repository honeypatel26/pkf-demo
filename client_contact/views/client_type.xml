<odoo>
    <record id="client_type_view_form" model="ir.ui.view">
        <field name="name">client.type.form</field>
        <field name="model">client.type</field>
        <field name="arch" type="xml">
            <form string="Client Type">
                <sheet>
                    <group>
                       <field name="name" string="Client Type"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="client_type_list_view" model="ir.ui.view">
        <field name="name">client.type.List</field>
        <field name="model">client.type</field>
        <field name="arch" type="xml">
            <list string="Client Type">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="client_type_action" model="ir.actions.act_window">
        <field name="name">Client Type</field>
        <field name="res_model">client.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new record
            </p>
        </field>
    </record>
</odoo>
