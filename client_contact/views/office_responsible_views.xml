<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="office_responsible_view_form" model="ir.ui.view">
        <field name="name">office.responsible.form</field>
        <field name="model">office.responsible</field>
        <field name="arch" type="xml">
            <form string="Office Responsible">
                <sheet>
                    <group>
                       <field name="name" string="Office Responsible"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="office_responsible_list_view" model="ir.ui.view">
        <field name="name">office.responsible.List</field>
        <field name="model">office.responsible</field>
        <field name="arch" type="xml">
            <list string="Office Responsible">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="office_responsible_action" model="ir.actions.act_window">
        <field name="name">Office Responsible</field>
        <field name="res_model">office.responsible</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new record
            </p>
        </field>
    </record>
</odoo>
