<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Client Action for Dashboard -->
    <record id="action_dashboard_client" model="ir.actions.client">
        <field name="name">GPMA Dashboard</field>
        <field name="tag">galaxy_practice_management_app.dashboard</field>
        <field name="params" eval="{
            'actions': [
                {'name': 'My Timesheets', 'xml_id': 'hr_timesheet.act_hr_timesheet_line', 'view_mode': 'list'},

                {'name': 'Projects', 'xml_id': 'project.open_view_project_all'},
                {'name': 'My Tasks', 'xml_id': 'galaxy_practice_management_app.action_my_tasks_kanban', 'view_mode': 'kanban'},
                {'name': 'Contacts with Ongoing Tasks', 'xml_id': 'galaxy_practice_management_app.action_contacts_ongoing_tasks', 'view_mode': 'list'},
            ]
        }"/>
    </record>

    <!-- Define the custom actions used in the dashboard (from previous dashboard_view.xml) -->
    
     <!-- Custom Action for Contacts with Ongoing Tasks -->
    <record id="action_contacts_ongoing_tasks" model="ir.actions.act_window">
        <field name="name">Contacts with Ongoing Tasks</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('task_ids.stage_id.fold', '=', False)]</field>
        <field name="context">{'create': False}</field>
    </record>

    <!-- Custom Action for My Tasks -->
    <record id="action_my_tasks_kanban" model="ir.actions.act_window">
        <field name="name">My Tasks</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('user_ids', 'in', [uid])]</field>
        <field name="context">{'search_default_my_tasks': 1}</field>
    </record>

</odoo>
